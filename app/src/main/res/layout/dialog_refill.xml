<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView android:id="@+id/tvRefillHint"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="13sp" android:textColor="#888888"
        android:lineSpacingMultiplier="1.4" android:layout_marginBottom="14dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="ဆီဖြည့်ပမာဏ (လီတာ)"
        android:textSize="14sp" android:layout_marginBottom="6dp"/>

    <EditText android:id="@+id/etRefillLitres"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="ဥပမာ: 15.5"
        android:inputType="numberDecimal"
        android:textSize="20sp" android:paddingVertical="8dp"
        android:layout_marginBottom="16dp"/>

    <Button android:id="@+id/btnPickDate"
        android:layout_width="match_parent" android:layout_height="44dp"
        android:text="📅 ဆီဖြည့်ရက် ရွေးချယ်မည်"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>

    <TextView android:id="@+id/tvDateChosen"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="13sp" android:textColor="#FFC107"
        android:gravity="center" android:layout_marginBottom="4dp"/>

</LinearLayout>
